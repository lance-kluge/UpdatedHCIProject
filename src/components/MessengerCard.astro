---
interface Message {
  id: string;
  name: string;
  lastMessage: string;
  time: string;
  unread?: boolean;
  avatarUrl?: string;
  type: string; // must match normalized filter: 'sent-messages', 'pending-responses', 'important-messages'
}

interface Props {
  message: Message;
}

const { message } = Astro.props as Props;

const normalize = (str: string) =>
  str.toLowerCase().replace(/\s/g, '-').replace(/[^a-z0-9-]/g, '');
---

<article
  class="flex items-center gap-5 rounded-xl border border-slate-200 bg-white px-6 py-5"
  data-message-card
  data-message-type={normalize(message.type)}
>
  <div class="h-14 w-14 shrink-0 rounded-full bg-slate-200"></div>
  <div class="min-w-0 flex-1">
    <div class="flex items-center gap-2">
      <h3 class="truncate text-lg font-semibold text-slate-900">{message.name}</h3>
      <p class="ml-auto text-base text-slate-500">{message.time}</p>
    </div>
    <p class="mt-1.5 truncate text-base text-slate-600">{message.lastMessage}</p>
  </div>
  {message.unread && <div class="h-3.5 w-3.5 rounded-full bg-blue-500"></div>}
</article>
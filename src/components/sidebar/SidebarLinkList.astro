---
interface Props {
  items: string[];
  indentClass?: string;
  filterGroup?: string;
  hrefBase?: string;
}

const { items, indentClass = 'pl-5', filterGroup, hrefBase } = Astro.props;

const normalize = (str: string) =>
  str.toLowerCase().replace(/\s/g, '-').replace(/[^a-z0-9-]/g, '');
---

<ul class="mt-1 space-y-1">
  {items.map((item) => {
    const value = filterGroup ? normalize(item) : undefined;

    return (
      <li>
        {hrefBase ? (
          <a
            href={`${hrefBase}${encodeURIComponent(value ?? '')}`}
            data-filter-group={filterGroup}
            data-filter-value={value}
            class={`block w-full rounded-md px-3 py-2 text-left text-sm text-slate-700 hover:bg-slate-100 hover:text-slate-900 ${indentClass}`}
          >
            {item}
          </a>
        ) : (
          <button
            type="button"
            data-filter-group={filterGroup}
            data-filter-value={value}
            class={`w-full rounded-md px-3 py-2 text-left text-sm text-slate-700 hover:bg-slate-100 hover:text-slate-900 ${indentClass}`}
          >
            {item}
          </button>
        )}
      </li>
    );
  })}
</ul>
---
import type { ThreadMock, ThreadStatus } from '../data/home';

interface Props {
  thread: ThreadMock;
}

const { thread } = Astro.props;

const statusSquareClass: Record<ThreadStatus, string> = {
  red: 'bg-red-500',
  orange: 'bg-orange-500',
  green: 'bg-green-500'
};

const statusTextClass: Record<ThreadStatus, string> = {
  red: 'text-red-600',
  orange: 'text-orange-600',
  green: 'text-green-600'
};

const getInstructorNotice = (thread: ThreadMock) => {
  const state = thread.instructorNotifyState ?? (thread.footerLabel ? 'notified' : 'not-notified');

  if (state === 'notified') {
    return {
      label: 'Instructor notified',
      toneClass: 'bg-emerald-50 text-emerald-700 border-emerald-200'
    };
  }

  if (state === 'scheduled') {
    const hours = thread.instructorNotifyInHours ?? 6;
    return {
      label: `Instructor set to be notified in ${hours} hours`,
      toneClass: 'bg-[#CFB87C]/18 text-slate-900 border-[#CFB87C]/60'
    };
  }

  return {
    label: 'Instructor not to be notified',
    toneClass: 'bg-slate-100 text-slate-700 border-slate-200'
  };
};

const instructorNotice = getInstructorNotice(thread);

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;

const threadHref =
  withBase(
    thread.href ?? `/threads/not-implemented/?thread=${encodeURIComponent(thread.title)}&id=${thread.id}`
  );

const normalize = (str: string) =>
  str.toLowerCase().replace(/\s/g, '-').replace(/[^a-z0-9-]/g, '');
---

<article
  class="flex items-start gap-5 rounded-xl border border-slate-200 bg-white px-6 py-5"
  data-thread-card
  data-thread-category={normalize(thread.category)}
>
  <div class="min-w-0 flex-1">
    <div class="flex items-center gap-3">
      <div class={`h-5 w-5 shrink-0 rounded-sm ${statusSquareClass[thread.status]}`}></div>
      <h3 class="truncate text-xl font-semibold text-slate-900">{thread.title}</h3>
      <p class={`ml-auto shrink-0 text-base font-semibold ${statusTextClass[thread.status]}`}>
        {thread.statusLabel}
      </p>
    </div>
    <p class="mt-2.5 text-base text-slate-600">{thread.aiSummary}</p>
    <div class={`mt-3 inline-flex items-center rounded-md border px-3 py-1.5 text-sm font-semibold ${instructorNotice.toneClass}`}>
      {instructorNotice.label}
    </div>
  </div>

  <a
    href={threadHref}
    aria-label={`Open ${thread.title}`}
    class="shrink-0 rounded-md border border-slate-300 bg-white px-4 py-2.5 text-lg text-slate-900 transition hover:bg-slate-50"
  >
    →
  </a>
</article>
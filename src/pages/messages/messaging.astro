---
import LeftSidebar from '../../components/sidebar/LeftSidebar.astro';
import TopBarHeader from '../../components/TopBarHeader.astro';
import MessengerCard from '../../components/MessengerCard.astro';
import { mockMessages } from '../../data/messages';
import { unreadCount } from '../../data/sidebar';
import '../../styles/global.css';

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
const blockedMessageNames = ['ben', 'professor'];
const isBlockedMessageName = (name: string) =>
  blockedMessageNames.some((blockedName) => name.trim().toLowerCase().startsWith(blockedName));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <meta name="viewport" content="width=device-width" />
    <title>Messages</title>
  </head>
  <body class="min-h-screen bg-[#565A5C]/20 text-slate-900">
    <main class="flex min-h-screen">
      <LeftSidebar />
      <div class="flex min-h-screen flex-1 flex-col">
        <TopBarHeader title="Messages" unreadCount={unreadCount} />

        <section class="flex-1 overflow-y-auto p-8 lg:p-12">
          <div class="space-y-6">

            <div id="mock-send-banner" class="hidden rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900">
              <p class="font-semibold">Success: Message sent (mock).</p>
              <p class="mt-1 text-emerald-800">Demo disclaimer: no message was actually saved.</p>
            </div>

            <div class="flex items-center justify-between rounded-xl border-2 border-[#CFB87C] bg-white px-6 py-5">
              <h2 class="text-base font-semibold uppercase tracking-wide text-slate-800">Messages</h2>
              <a
                href={withBase('/posts/newMessage/')}
                class="rounded-md bg-slate-900 px-5 py-2.5 text-base font-semibold text-[#CFB87C] transition hover:bg-black"
              >
                New Message
              </a>
            </div>

            <div id="message-cards" class="space-y-4.5">
              {mockMessages.filter(msg => !isBlockedMessageName(msg.name)).map(msg => (
                <div data-message-card data-message-category={msg.type.toLowerCase()}>
                  <MessengerCard message={msg} />
                </div>
              ))}
            </div>

          </div>
        </section>
      </div>
    </main>

    <script is:inline>
      const normalize = str => str.toLowerCase().replace(/\s/g, '-').replace(/[^a-z0-9-]/g, '');
      const samePath = (a, b) => a.replace(/\/$/, '') === b.replace(/\/$/, '');
      const pageParams = new URLSearchParams(window.location.search);
      const mockSendBanner = document.getElementById('mock-send-banner');
      const blockedMessageNames = ['ben', 'professor'];
      const isBlockedMessageName = (name) =>
        blockedMessageNames.some((blockedName) => String(name || '').trim().toLowerCase().startsWith(blockedName));

      if (mockSendBanner && pageParams.get('mockSent') === '1') {
        mockSendBanner.classList.remove('hidden');
        pageParams.delete('mockSent');
        const cleanedQuery = pageParams.toString();
        const cleanedUrl = `${window.location.pathname}${cleanedQuery ? `?${cleanedQuery}` : ''}${window.location.hash}`;
        window.history.replaceState({}, '', cleanedUrl);
      }

      function setupFilters(group, queryParam) {
        const cards = Array.from(document.querySelectorAll(`[data-${group}-card]`));
        const controls = Array.from(
          document.querySelectorAll(`[data-filter-group="${group}"][data-filter-value]`)
        );
        const activeClass = ['bg-[#CFB87C]/35', 'text-slate-950'];
        const params = new URLSearchParams(window.location.search);

        function applyFilter(filterValue) {
          const normalizedFilter = filterValue === 'all' ? 'all' : normalize(filterValue);
          cards.forEach(card => {
            const category = normalize(card.dataset[`${group}Category`] || card.dataset[`${group}Type`] || '');
            card.classList.toggle('hidden', normalizedFilter !== 'all' && category !== normalizedFilter);
          });

          controls.forEach(control => {
            const isActive = normalize(control.getAttribute('data-filter-value')) === normalizedFilter;
            activeClass.forEach(cls => control.classList.toggle(cls, isActive));
            if (control.tagName === 'BUTTON') control.setAttribute('aria-pressed', String(isActive));
          });

          if (queryParam) {
            if (normalizedFilter === 'all') {
              params.delete(queryParam);
            } else {
              params.set(queryParam, normalizedFilter);
            }

            const nextQuery = params.toString();
            const nextUrl = `${window.location.pathname}${nextQuery ? `?${nextQuery}` : ''}${window.location.hash}`;
            window.history.replaceState({}, '', nextUrl);
          }
        }

        controls.forEach(control => control.addEventListener('click', (e) => {
          if (control.tagName === 'A') {
            const targetUrl = new URL(control.href, window.location.origin);
            if (samePath(targetUrl.pathname, window.location.pathname)) {
              e.preventDefault();
            }
          }

          applyFilter(control.getAttribute('data-filter-value'));
        }));

        const initialFilter = queryParam ? params.get(queryParam) || 'all' : 'all';
        applyFilter(initialFilter);
      }

      // -----------------------------
      // Add localStorage messages first
      // -----------------------------
      const container = document.getElementById('message-cards');
      const storedMessages = JSON.parse(localStorage.getItem('messages') || '[]');

      storedMessages.forEach(msg => {
        if (isBlockedMessageName(msg.name)) {
          return;
        }

        const wrapper = document.createElement('div');
        wrapper.dataset.messageCard = '';
        wrapper.dataset.messageCategory = msg.type.toLowerCase();
        wrapper.innerHTML = `
          <article class="flex items-center gap-5 rounded-xl border border-slate-200 bg-white px-6 py-5">
            <div class="h-14 w-14 shrink-0 rounded-full bg-slate-200"></div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <h3 class="truncate text-lg font-semibold text-slate-900">${msg.name}</h3>
                <p class="ml-auto text-base text-slate-500">${msg.time}</p>
              </div>
              <p class="mt-1.5 truncate text-base text-slate-600">${msg.lastMessage}</p>
            </div>
            ${msg.unread ? '<div class="h-3.5 w-3.5 rounded-full bg-blue-500"></div>' : ''}
          </article>
        `;
        container.appendChild(wrapper);
      });

      // -----------------------------
      // Now setup filters after all cards exist
      // -----------------------------
      setupFilters('thread', 'threadFilter');
      setupFilters('message', 'messageFilter');
    </script>
  </body>
</html>
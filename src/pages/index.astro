---
import LeftSidebar from '../components/sidebar/LeftSidebar.astro';
import TopBarHeader from '../components/TopBarHeader.astro';
import ThreadCard from '../components/ThreadCard.astro';
import { mockThreads } from '../data/home';
import { unreadCount } from '../data/sidebar';
import '../styles/global.css';

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <meta name="viewport" content="width=device-width" />
    <title>Threads</title>
  </head>
  <body class="min-h-screen bg-slate-100 text-slate-900">
    <main class="flex min-h-screen">
      <LeftSidebar />
      <div class="flex min-h-screen flex-1 flex-col">
        <TopBarHeader title="Messenger" unreadCount={unreadCount} />
        <section id="threads" class="flex-1 p-8 lg:p-12">
          <div class="space-y-5">
            <div id="mock-thread-banner" class="hidden rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900">
              <p class="font-semibold">Success: Thread post saved (mock).</p>
              <p class="mt-1 text-emerald-800">Demo disclaimer: nothing was actually posted or saved.</p>
            </div>

            <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-6 py-5">
              <h2 class="text-base font-semibold uppercase tracking-wide text-slate-800">Threads</h2>
              <a
                href={withBase('/posts/new/')}
                class="rounded-md bg-green-600 px-5 py-2.5 text-base font-semibold text-white transition hover:bg-green-700"
              >
                New Post
              </a>
            </div>

            <div class="space-y-4.5">
              {mockThreads.map(thread => (
                <ThreadCard thread={thread} />
              ))}
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-5 text-base text-slate-700">
              <span class="font-semibold text-green-700">Green</span> is question answered,
              <span class="font-semibold text-orange-700"> Orange</span> is 0-48 hours,
              <span class="font-semibold text-red-700"> Red</span> is anything past 2 days.
            </div>
          </div>
        </section>
      </div>
    </main>

    <script is:inline>
      const normalize = str => str.toLowerCase().replace(/\s/g, '-').replace(/[^a-z0-9-]/g, '');
      const samePath = (a, b) => a.replace(/\/$/, '') === b.replace(/\/$/, '');
      const pageParams = new URLSearchParams(window.location.search);
      const mockThreadBanner = document.getElementById('mock-thread-banner');

      if (mockThreadBanner && pageParams.get('threadMockPosted') === '1') {
        mockThreadBanner.classList.remove('hidden');
        pageParams.delete('threadMockPosted');
        const cleanedQuery = pageParams.toString();
        const cleanedUrl = `${window.location.pathname}${cleanedQuery ? `?${cleanedQuery}` : ''}${window.location.hash}`;
        window.history.replaceState({}, '', cleanedUrl);
      }

      function setupFilters(group, queryParam) {
        const cards = Array.from(document.querySelectorAll(`[data-${group}-card]`));
        const controls = Array.from(
          document.querySelectorAll(`[data-filter-group="${group}"][data-filter-value]`)
        );
        const activeClass = ['bg-slate-200', 'text-slate-900'];
        const params = new URLSearchParams(window.location.search);

        function applyFilter(filterValue) {
          const normalizedFilter = filterValue === 'all' ? 'all' : normalize(filterValue);
          cards.forEach(card => {
            const category = normalize(card.dataset[`${group}Category`] || card.dataset[`${group}Type`] || '');
            card.classList.toggle('hidden', normalizedFilter !== 'all' && category !== normalizedFilter);
          });

          controls.forEach(control => {
            const isActive = normalize(control.getAttribute('data-filter-value')) === normalizedFilter;
            activeClass.forEach(cls => control.classList.toggle(cls, isActive));
            if (control.tagName === 'BUTTON') control.setAttribute('aria-pressed', String(isActive));
          });

          if (queryParam) {
            if (normalizedFilter === 'all') {
              params.delete(queryParam);
            } else {
              params.set(queryParam, normalizedFilter);
            }

            const nextQuery = params.toString();
            const nextUrl = `${window.location.pathname}${nextQuery ? `?${nextQuery}` : ''}${window.location.hash}`;
            window.history.replaceState({}, '', nextUrl);
          }
        }

        controls.forEach(control => control.addEventListener('click', (e) => {
          if (control.tagName === 'A') {
            const targetUrl = new URL(control.href, window.location.origin);
            if (samePath(targetUrl.pathname, window.location.pathname)) {
              e.preventDefault();
            }
          }

          applyFilter(control.getAttribute('data-filter-value'));
        }));

        const initialFilter = queryParam ? params.get(queryParam) || 'all' : 'all';
        applyFilter(initialFilter);
      }

      setupFilters('thread', 'threadFilter');
      setupFilters('message', 'messageFilter');
    </script>
  </body>
</html>
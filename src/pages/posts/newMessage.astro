---
import LeftSidebar from '../../components/sidebar/LeftSidebar.astro';
import TopBarHeader from '../../components/TopBarHeader.astro';
import { mockPeople } from '../../data/people';
import { unreadCount } from '../../data/sidebar';
import '../../styles/global.css';

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
const messagingPath = withBase('/messages/messaging/');
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" href={withBase('/favicon.ico')} />
  <meta name="viewport" content="width=device-width" />
  <title>New Message</title>
</head>
<body class="min-h-screen bg-[#565A5C]/20 text-slate-900">
  <main class="flex min-h-screen">
    <LeftSidebar />

    <div class="flex min-h-screen flex-1 flex-col">
      <TopBarHeader title="New Message" unreadCount={unreadCount} />

      <section class="flex-1 p-6 lg:p-10">
        <div class="mx-auto max-w-3xl space-y-6">
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <h1 class="text-2xl font-semibold text-slate-900 mb-4">Compose New Message</h1>

            <form id="newMessageForm" class="space-y-5">
              <div class="space-y-1">
                <label for="recipient-input" class="text-xs font-semibold uppercase tracking-wide text-slate-500">Recipients</label>
                <div class="min-h-14 rounded-md border border-slate-300 px-3 py-2 focus-within:border-blue-500 focus-within:ring-2 focus-within:ring-blue-200">
                  <div id="recipient-chip-list" class="flex flex-wrap gap-2"></div>
                  <div class="relative mt-1">
                  <input
                    id="recipient-input"
                    type="text"
                    placeholder="Search people and press Enter"
                    autocomplete="off"
                    class="w-full border-0 p-0 text-sm text-slate-800 outline-none ring-0 placeholder:text-slate-400 focus:ring-0"
                  />
                  <div id="recipient-suggestions" class="absolute z-10 mt-2 hidden w-full overflow-hidden rounded-lg border border-slate-200 bg-white shadow-lg">
                    <div class="border-b border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold uppercase tracking-wide text-slate-500">
                      People
                    </div>
                    <div id="recipient-suggestion-list" class="max-h-72 overflow-y-auto"></div>
                  </div>
                  </div>
                </div>
                <p class="text-xs text-slate-500">Type a name to filter the class roster.</p>
              </div>

              <label class="block space-y-1">
                <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">Message</span>
                <textarea
                  name="body"
                  rows="6"
                  placeholder="Type your message here"
                  class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-800"
                  required
                ></textarea>
              </label>

              <div class="flex justify-end gap-2">
                <a
                  href={messagingPath}
                  class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
                >
                  Cancel
                </a>
                <button
                  type="submit"
                  class="rounded-md bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700"
                >
                  Send
                </button>
              </div>
            </form>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script is:inline define:vars={{ messagingPath, mockPeople }}>
    const form = document.getElementById('newMessageForm');
    const recipientInput = document.getElementById('recipient-input');
    const recipientSuggestions = document.getElementById('recipient-suggestions');
    const recipientSuggestionList = document.getElementById('recipient-suggestion-list');
    const recipientChipList = document.getElementById('recipient-chip-list');

    const people = mockPeople;
    const selectedPeople = [];

    const roleStyles = {
      student: 'bg-blue-50 text-blue-700 border-blue-100',
      professor: 'bg-amber-50 text-amber-800 border-amber-100'
    };

    const findPerson = (name) => people.find((person) => person.name === name);

    const setSuggestionsVisible = (visible) => {
      if (!recipientSuggestions) return;
      recipientSuggestions.classList.toggle('hidden', !visible);
    };

    const syncHiddenRecipientValue = () => {
      let hiddenRecipientInput = form.querySelector('input[name="recipientList"]');

      if (!hiddenRecipientInput) {
        hiddenRecipientInput = document.createElement('input');
        hiddenRecipientInput.type = 'hidden';
        hiddenRecipientInput.name = 'recipientList';
        form.appendChild(hiddenRecipientInput);
      }

      hiddenRecipientInput.value = selectedPeople.map((person) => person.name).join(', ');
      recipientInput.setCustomValidity(selectedPeople.length > 0 ? '' : 'Add at least one recipient.');
    };

    const removeSelectedPerson = (name) => {
      const index = selectedPeople.findIndex((person) => person.name === name);
      if (index === -1) return;

      selectedPeople.splice(index, 1);
      renderSelectedPeople();
      renderSuggestions(recipientInput?.value || '');
      syncHiddenRecipientValue();
    };

    const addSelectedPerson = (person) => {
      if (selectedPeople.some((selected) => selected.name === person.name)) return;

      selectedPeople.push(person);
      renderSelectedPeople();
      syncHiddenRecipientValue();
      if (recipientInput) {
        recipientInput.value = '';
      }
      renderSuggestions('');
      setSuggestionsVisible(false);
    };

    function renderSelectedPeople() {
      if (!recipientChipList) return;

      recipientChipList.innerHTML = selectedPeople
        .map((person) => {
          const badgeClass = roleStyles[person.role];
          const roleLabel = person.role === 'professor' ? 'Professor' : 'Student';

          return `
            <span class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-sm font-medium ${badgeClass}">
              <span>${person.name}</span>
              <button
                type="button"
                data-remove-name="${person.name}"
                class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-white/70 text-current transition hover:bg-white"
                aria-label="Remove ${person.name}"
              >
                ×
              </button>
            </span>
          `;
        })
        .join('');

      recipientChipList.querySelectorAll('button[data-remove-name]').forEach((button) => {
        button.addEventListener('click', () => {
          const name = button.getAttribute('data-remove-name');
          if (name) removeSelectedPerson(name);
        });
      });
    }

    const renderSuggestions = (query = '') => {
      if (!recipientSuggestions || !recipientSuggestionList) return;

      const normalizedQuery = query.trim().toLowerCase();
      const matches = people.filter((person) => {
        const notSelected = !selectedPeople.some((selected) => selected.name === person.name);
        const matchesQuery = normalizedQuery ? person.name.toLowerCase().includes(normalizedQuery) : true;
        return notSelected && matchesQuery;
      });

      if (matches.length === 0) {
        recipientSuggestionList.innerHTML = '';
        setSuggestionsVisible(false);
        return;
      }

      recipientSuggestionList.innerHTML = matches
        .map((person) => {
          const badgeClass = roleStyles[person.role];
          const roleLabel = person.role === 'professor' ? 'Professor' : 'Student';

          return `
            <button
              type="button"
              data-person-name="${person.name}"
              class="flex w-full items-center justify-between gap-3 border-b border-slate-100 px-3 py-3 text-left transition hover:bg-slate-50 last:border-b-0"
            >
              <span class="text-sm font-medium text-slate-900">${person.name}</span>
              <span class="rounded-full border px-2.5 py-0.5 text-xs font-semibold ${badgeClass}">${roleLabel}</span>
            </button>
          `;
        })
        .join('');

      recipientSuggestions.classList.toggle('hidden', matches.length === 0);

      recipientSuggestionList.querySelectorAll('button[data-person-name]').forEach((button) => {
        button.addEventListener('click', () => {
          const selectedName = button.getAttribute('data-person-name');
          const person = selectedName ? findPerson(selectedName) : undefined;
          if (person) addSelectedPerson(person);
          recipientInput.focus();
        });
      });
    };

    if (recipientInput && recipientSuggestions) {
      renderSelectedPeople();
      syncHiddenRecipientValue();

      recipientInput.addEventListener('focus', () => {
        renderSuggestions(recipientInput.value);
        setSuggestionsVisible(true);
      });

      recipientInput.addEventListener('input', () => {
        renderSuggestions(recipientInput.value);
        setSuggestionsVisible(true);
      });

      recipientInput.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          const firstMatch = people.find((person) => {
            const alreadySelected = selectedPeople.some((selected) => selected.name === person.name);
            const matchesQuery = person.name.toLowerCase().includes(recipientInput.value.trim().toLowerCase());
            return !alreadySelected && matchesQuery;
          });

          if (firstMatch) {
            addSelectedPerson(firstMatch);
          }
        }
      });

      recipientInput.addEventListener('blur', () => {
        window.setTimeout(() => recipientSuggestions.classList.add('hidden'), 120);
      });
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      if (selectedPeople.length === 0) {
        recipientInput?.setCustomValidity('Add at least one recipient.');
        recipientInput?.reportValidity();
        return;
      }

      recipientInput?.setCustomValidity('');

      // Mock-only send: do not persist message data.
      const redirectUrl = new URL(messagingPath, window.location.origin);
      redirectUrl.searchParams.set('mockSent', '1');
      window.location.href = redirectUrl.toString();
    });
  </script>
</body>
</html>